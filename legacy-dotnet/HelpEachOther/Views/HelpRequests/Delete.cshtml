@model HelpRequest
@{
    ViewData["Title"] = "Delete Request";
}

<h2>Delete Help Request</h2>

<div class="card shadow-sm border-danger">
    <div class="card-body">
        <p class="text-danger fw-semibold">Are you sure you want to delete this request?</p>
        <p><strong>Title:</strong> @Model.Title</p>
        <p><strong>Category:</strong> @Model.Category</p>
        <p><strong>City:</strong> @Model.City</p>
        <p><strong>Status:</strong> @Model.Status</p>
    </div>
    <div class="card-footer bg-white d-flex gap-2">
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button class="btn btn-danger" type="submit">Yes, delete</button>
        </form>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</div>
